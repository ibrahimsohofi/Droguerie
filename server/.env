# Development Environment Configuration
PORT=5000
NODE_ENV=development
API_BASE_URL=http://localhost:5000

# Database Configuration (SQLite for development)
DATABASE_URL=./database.sqlite
DB_NAME=droguerie_jamal

# JWT Configuration
JWT_SECRET=dev_jwt_secret_key_for_development_only_change_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=dev_refresh_token_secret_for_development_only
REFRESH_TOKEN_EXPIRES_IN=30d

# Email Configuration (Using Ethereal for development testing)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Droguerie Jamal" <no-reply@drogueriejamal.ma>

# Email Features
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET_EMAIL=true
ENABLE_ORDER_CONFIRMATION_EMAIL=true
EMAIL_VERIFICATION_EXPIRES_IN=24h

# Stripe Configuration (test mode)
STRIPE_SECRET_KEY=sk_test_dev_key
STRIPE_PUBLISHABLE_KEY=pk_test_dev_key
STRIPE_WEBHOOK_SECRET=whsec_dev_webhook_secret

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp
MAX_FILES_PER_UPLOAD=10

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Admin Configuration
ADMIN_EMAIL=admin@jamalgeneralstore.dev
ADMIN_PASSWORD=admin123

# Business Configuration
BUSINESS_NAME="Jamal General Store"
BUSINESS_EMAIL=contact@jamalgeneralstore.dev
BUSINESS_PHONE="+212 522 123 456"
BUSINESS_ADDRESS="123 Rue Hassan II, Casablanca, Morocco"
BUSINESS_HOURS="Mon-Sat: 8:00-20:00, Sun: 9:00-18:00"

# WhatsApp Business API Configuration
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_PHONE="+212522123456"
WHATSAPP_VERIFY_TOKEN=droguerie_jamal_webhook_verify_token

# WhatsApp Features
ENABLE_WHATSAPP_NOTIFICATIONS=true
ENABLE_WHATSAPP_ORDER_CONFIRMATIONS=true
ENABLE_WHATSAPP_ORDER_TRACKING=true
