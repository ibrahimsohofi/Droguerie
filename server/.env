# Development Environment Configuration
PORT=5000
NODE_ENV=development
API_BASE_URL=http://localhost:5000

# Database Configuration (SQLite for development)
DATABASE_URL=./database.sqlite
DB_NAME=droguerie_jamal

# JWT Configuration
JWT_SECRET=dev_jwt_secret_key_for_development_only_change_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=dev_refresh_token_secret_for_development_only
REFRESH_TOKEN_EXPIRES_IN=30d

# Email Configuration (development - no emails sent)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=dev@example.com
SMTP_PASS=dev_password
SMTP_FROM="Droguerie Jamal Dev" <dev@example.com>

# Stripe Configuration (test mode)
STRIPE_SECRET_KEY=sk_test_dev_key
STRIPE_PUBLISHABLE_KEY=pk_test_dev_key
STRIPE_WEBHOOK_SECRET=whsec_dev_webhook_secret

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp
MAX_FILES_PER_UPLOAD=10

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Admin Configuration
ADMIN_EMAIL=admin@droguerie.dev
ADMIN_PASSWORD=admin123

# Business Configuration
BUSINESS_NAME="Droguerie Jamal"
BUSINESS_EMAIL=contact@droguerie.dev
BUSINESS_PHONE="+212 522 123 456"
BUSINESS_ADDRESS="123 Rue Hassan II, Casablanca, Morocco"
BUSINESS_HOURS="Mon-Sat: 8:00-20:00, Sun: 9:00-18:00"
