# =================================================================
# DROGUERIE JAMAL CLIENT - PRODUCTION CONFIGURATION
# =================================================================

# Backend API URL (REQUIRED: Update with your backend domain)
VITE_API_URL=https://api.drogueriejamal.ma

# =================================================================
# STRIPE PAYMENT CONFIGURATION (PRODUCTION)
# =================================================================

# PRODUCTION: Live Stripe Publishable Key
# Get from: https://dashboard.stripe.com/apikeys
# IMPORTANT: Use LIVE keys for production (pk_live_...)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_LIVE_PUBLISHABLE_KEY_HERE

# =================================================================
# OAUTH CONFIGURATION (PRODUCTION)
# =================================================================

# Google OAuth (Production - Get from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Facebook OAuth (Production - Get from Facebook Developer Console)
# https://developers.facebook.com/apps/
VITE_FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID

# =================================================================
# APP CONFIGURATION
# =================================================================

# App metadata
VITE_APP_NAME="دروغيري جمال - Droguerie Jamal"
VITE_APP_DESCRIPTION="دروغيريتك المحلية الموثوقة - Your trusted neighborhood droguerie"
VITE_APP_VERSION=1.0.0

# Business contact
VITE_BUSINESS_PHONE="+212522123456"
VITE_BUSINESS_EMAIL="contact@drogueriejamal.ma"
VITE_BUSINESS_ADDRESS="123 Rue Hassan II, Casablanca, Morocco"

# WhatsApp Business
VITE_WHATSAPP_NUMBER="+212522123456"
VITE_WHATSAPP_MESSAGE="مرحبا، أريد الاستفسار عن المنتجات - Hello, I want to inquire about products"

# =================================================================
# ANALYTICS & MONITORING (OPTIONAL)
# =================================================================

# Google Analytics (Optional)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry Error Tracking (Optional)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =================================================================
# ✅ 1. Update VITE_API_URL with your backend domain
# ✅ 2. Add real Stripe live publishable key
# ✅ 3. Configure Google OAuth for production domain
# ✅ 4. Configure Facebook OAuth for production domain
# ⚠️  5. Test all payment flows in Stripe test mode first
# ⚠️  6. Ensure HTTPS is enabled on your domain
# ⚠️  7. Test PWA installation on mobile devices
# ⚠️  8. Configure CDN for static assets (optional)
# ⚠️  9. Set up domain SSL certificate
# ⚠️  10. Test app functionality thoroughly before launch
